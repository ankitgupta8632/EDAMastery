generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── User ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String   @default("Learner")
  createdAt DateTime @default(now())

  lessonProgress LessonProgress[]
  quizAttempts   QuizAttempt[]
  achievements   UserAchievement[]
  streak         Streak?
  sessions       LearningSession[]
  settings       UserSettings?
  reviewItems    ReviewItem[]
}

// ─── Curriculum Structure ───────────────────────────────────────────────────

model Phase {
  id          String @id // e.g. "phase-1"
  name        String
  description String
  order       Int
  colorHex    String @default("#6366f1")

  modules Module[]
}

model Module {
  id             String  @id // e.g. "digital-design"
  name           String
  description    String
  order          Int
  estimatedHours Float
  phaseId        String
  notebookId     String? // NotebookLM notebook ID
  notebookUrl    String?

  phase          Phase                @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  lessons        Lesson[]
  prerequisites  ModulePrerequisite[] @relation("ModulePrereqs")
  prerequisiteOf ModulePrerequisite[] @relation("ModulePrereqOf")
}

model ModulePrerequisite {
  moduleId       String
  prerequisiteId String

  module       Module @relation("ModulePrereqs", fields: [moduleId], references: [id], onDelete: Cascade)
  prerequisite Module @relation("ModulePrereqOf", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@id([moduleId, prerequisiteId])
}

// ─── Lessons & Content ──────────────────────────────────────────────────────

model Lesson {
  id                String    @id @default(cuid())
  slug              String
  title             String
  description       String
  order             Int
  estimatedMinutes  Int       @default(15)
  contentType       String    @default("mixed") // "audio", "visual", "mixed"
  difficulty        String    @default("beginner") // "beginner", "intermediate", "advanced"
  moduleId          String
  contentMarkdown   String? // the lesson text content
  contentJson       String? // structured JSON
  videoUrl          String? // NotebookLM video overview
  audioUrl          String?
  audioTranscript   String?
  videoTranscript   String? // VTT/SRT subtitles for video
  flashcardsJson    String? // JSON array of {front, back} flashcards
  infographicUrl    String? // NotebookLM infographic image
  protiumNote       String? // how this applies to Protium
  labUrl            String?
  labInstructions   String?
  contentStatus     String    @default("draft") // "draft", "generated", "reviewed", "published"
  generatedAt       DateTime?
  reviewedAt        DateTime?
  sourceQuery       String? // the NotebookLM query used

  module      Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]
  quiz        Quiz?
  reviewItems ReviewItem[]

  @@unique([moduleId, slug])
}

// ─── Progress & Spaced Repetition ───────────────────────────────────────────

model LessonProgress {
  id              String    @id @default(cuid())
  userId          String
  lessonId        String
  status          String    @default("not_started") // "not_started", "in_progress", "completed"
  completedAt     DateTime?
  timeSpentSec    Int       @default(0)
  audioProgress   Float     @default(0) // 0 to 1
  scrollPosition  Float     @default(0) // 0 to 1
  confidenceScore Int? // 1 to 5
  quizBestScore   Int? // 0 to 100
  lastReviewedAt  DateTime?
  nextReviewAt    DateTime?
  easeFactor      Float     @default(2.5)
  interval        Int       @default(0) // days
  repetitions     Int       @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// ─── Quizzes ────────────────────────────────────────────────────────────────

model Quiz {
  id       String @id @default(cuid())
  lessonId String @unique

  lesson    Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id            String  @id @default(cuid())
  quizId        String
  questionText  String
  questionType  String  @default("multiple_choice") // "multiple_choice", "true_false", "fill_blank"
  options       String // JSON string array
  correctAnswer String
  explanation   String?
  difficulty    String  @default("medium")
  order         Int

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id           String   @id @default(cuid())
  userId       String
  quizId       String
  score        Int // 0 to 100
  answers      String // JSON string
  timeSpentSec Int
  completedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

// ─── Spaced Repetition Review ───────────────────────────────────────────────

model ReviewItem {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  easeFactor  Float     @default(2.5)
  interval    Int       @default(1) // days
  repetitions Int       @default(0)
  nextReview  DateTime
  lastReview  DateTime?
  quality     Int? // 0-5 last review quality

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// ─── Gamification ───────────────────────────────────────────────────────────

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())
  notified      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model Streak {
  id                        String  @id @default(cuid())
  userId                    String  @unique
  currentStreak             Int     @default(0)
  longestStreak             Int     @default(0)
  lastActiveDate            String? // ISO date string
  graceDaysUsed             Int     @default(0)
  graceDaysMax              Int     @default(1)
  consecutiveDaysAfterGrace Int     @default(0)
  totalXp                   Int     @default(0)
  level                     Int     @default(1) // 1-5

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Sessions ───────────────────────────────────────────────────────────────

model LearningSession {
  id               String    @id @default(cuid())
  userId           String
  mode             String // "commute", "focus", "quick_win", "baby_napping", "review"
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  durationSec      Int?
  lessonsCompleted Int       @default(0)
  quizzesTaken     Int       @default(0)
  xpEarned         Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Settings ───────────────────────────────────────────────────────────────

model UserSettings {
  id                    String    @id @default(cuid())
  userId                String    @unique
  dailyGoalMinutes      Int       @default(15)
  weekendLearning       Boolean   @default(false)
  reminderTime          String? // "HH:MM"
  reminderEnabled       Boolean   @default(true)
  preferredMode         String    @default("auto") // "auto", "audio", "visual", "mixed"
  commuteStartTime      String    @default("08:00")
  commuteEndTime        String    @default("09:00")
  eveningStartTime      String    @default("20:00")
  eveningEndTime        String    @default("22:00")
  autoPlayAudio         Boolean   @default(true)
  playbackSpeed         Float     @default(1.0)
  overwhelmedMode       Boolean   @default(false)
  overwhelmedUntil      DateTime?
  reducedGoalMinutes    Int       @default(5)
  notebookLmConfigured  Boolean   @default(false)
  onboardingCompleted   Boolean   @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

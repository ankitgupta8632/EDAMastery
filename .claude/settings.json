{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "npm run *",
      "npx prisma *",
      "npx shadcn@latest *",
      "npx tsx scripts/*",
      "npx tsx prisma/*",
      "npx vercel *",
      "/usr/local/bin/npm *",
      "/usr/local/bin/npx *",
      "/usr/local/bin/node *",
      "python scripts/run.py *",
      "curl http://localhost:*",
      "curl https://eda-mastery.vercel.app/*",
      "lsof -i :*",
      "kill *",
      "sqlite3 *",
      "~/.turso/turso *"
    ]
  }
}
